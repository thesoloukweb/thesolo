---
// Header component specifically for About page with custom background
---

<header class="fixed top-0 left-0 right-0 z-40 transition-all duration-300" style="background-color: #102B2A;" id="header">
  <!-- Blue Light Card Discount Banner -->
  <div class="bg-brand-gold/10 border-b border-brand-gold/20 relative" id="blc-banner">
    <div class="container-custom flex items-center justify-center py-1.5 px-4">
      <a 
        href="https://www.bluelightcard.co.uk/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-center group"
      >
        <svg class="w-4 h-4 text-brand-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="font-josefin text-xs sm:text-sm text-white/90 group-hover:text-brand-gold transition-colors duration-300">
          <span class="text-brand-gold font-semibold">20% OFF</span> for Blue Light Card holders
        </span>
        <svg class="w-3 h-3 text-white/60 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-300 flex-shrink-0 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <button 
        class="absolute right-3 top-1/2 -translate-y-1/2 text-white/40 hover:text-white transition-colors duration-300 p-1"
        id="close-blc-banner"
        aria-label="Close banner"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
  <div class="container-custom">
    <div class="flex items-center justify-between py-4 px-4 sm:px-6 lg:px-0">
      
      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="TheSolo Kitchen & Bar - Home">
        <img 
          src="/images/logo.png" 
          alt="TheSolo Kitchen & Bar Logo" 
          class="h-12 sm:h-14 lg:h-16 w-auto"
          width="146"
          height="141"
        />
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8 xl:space-x-12" aria-label="Main navigation">
        <a 
          href="/" 
          class="font-crimson text-lg xl:text-xl text-white hover:text-brand-gold transition-colors duration-300"
        >
          Home
        </a>
        <a 
          href="/about" 
          class="font-crimson text-lg xl:text-xl text-brand-gold"
          aria-current="page"
        >
          About us
        </a>
        <a 
          href="/menu" 
          class="font-crimson text-lg xl:text-xl text-white hover:text-brand-gold transition-colors duration-300"
        >
          Menu
        </a>
        <a 
          href="/gallery" 
          class="font-crimson text-lg xl:text-xl text-white hover:text-brand-gold transition-colors duration-300"
        >
          Gallery
        </a>
        <a 
          href="/contact" 
          class="font-crimson text-lg xl:text-xl text-white hover:text-brand-gold transition-colors duration-300"
        >
          Contact Us
        </a>
      </nav>
      
      <!-- Reservation Button & Mobile Menu -->
      <div class="flex items-center space-x-4">
        <!-- Reservation Button (Desktop) -->
        <a 
          href="/reservation"
          class="hidden lg:inline-flex btn-primary px-6 py-2"
        >
          Reservation
        </a>
        
        <!-- Mobile Menu Button -->
        <button 
          class="lg:hidden p-2 text-white hover:text-brand-gold transition-colors duration-300"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          id="mobile-menu-button"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Menu -->
    <div 
      class="lg:hidden border-t border-brand-gold/20 hidden" 
      style="background-color: #102B2A;"
      id="mobile-menu"
      aria-hidden="true"
    >
      <div class="px-4 py-6 space-y-4">
        <a 
          href="/" 
          class="block font-crimson text-xl text-white hover:text-brand-gold transition-colors duration-300 py-2"
        >
          Home
        </a>
        <a 
          href="/about" 
          class="block font-crimson text-xl text-brand-gold py-2"
          aria-current="page"
        >
          About us
        </a>
        <a 
          href="/menu" 
          class="block font-crimson text-xl text-white hover:text-brand-gold transition-colors duration-300 py-2"
        >
          Menu
        </a>
        <a 
          href="/gallery" 
          class="block font-crimson text-xl text-white hover:text-brand-gold transition-colors duration-300 py-2"
        >
          Gallery
        </a>
        <a 
          href="/contact" 
          class="block font-crimson text-xl text-white hover:text-brand-gold transition-colors duration-300 py-2"
        >
          Contact Us
        </a>
        <div class="pt-4">
          <a 
            href="/reservation"
            class="btn-primary w-full text-center block"
          >
            Reservation
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Blue Light Card banner dismiss
    const blcBanner = document.getElementById('blc-banner');
    const closeBlcBtn = document.getElementById('close-blc-banner');
    
    if (blcBanner && sessionStorage.getItem('blc-banner-closed') === 'true') {
      blcBanner.style.display = 'none';
    }
    
    if (closeBlcBtn && blcBanner) {
      closeBlcBtn.addEventListener('click', function() {
        blcBanner.style.display = 'none';
        sessionStorage.setItem('blc-banner-closed', 'true');
      });
    }

    // Mobile menu toggle functionality
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        const isHidden = mobileMenu.classList.contains('hidden');
        
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          mobileMenuButton.setAttribute('aria-expanded', 'true');
          mobileMenu.setAttribute('aria-hidden', 'false');
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenuButton.setAttribute('aria-expanded', 'false');
          mobileMenu.setAttribute('aria-hidden', 'true');
        }
      });
    }
  });
</script>
